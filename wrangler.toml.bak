name = "thebookofyourlife"
main = "src/index.js"
compatibility_date = "2024-09-23"

# Import HTML as a text module
rules = [
  { type = "Text", globs = ["**/*.html"] }
]

# D1 Database binding
[[d1_databases]]
binding = "DB"
database_name = "thebookofyourlife-db"
database_id = "75a5bfdc-a7bd-4cca-b23c-cc71b7984bb7"
